type = "boolean"
optional = true

[elements.services]
typeof = "types.arrayOfServiceBindings"
optional = true

[elements.site]
typeof = "types.site"
optional = true

[elements.tail_consumers]
typeof = "types.arrayOfServiceBindings"
optional = true

[elements.triggers]
typeof = "types.triggers"
optional = true

