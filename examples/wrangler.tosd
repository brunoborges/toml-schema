type = "boolean"
optional = true

[elements.observability]
typeof = "types.observability"
optional = true

[elements.placement]
typeof = "types.placement"
optional = true

[elements.preserve_file_names]
type = "boolean"
optional = true

[elements.preview_urls]
type = "boolean"
optional = true

[elements.python_modules]
typeof = "types.pythonModules"
optional = true

[elements.queues]
typeof = "types.queues"
optional = true

[elements.r2_buckets]
typeof = "types.r2Buckets"
optional = true

[elements.route]
typeof = "types.route"
optional = true

[elements.routes]
typeof = "types.routes"
optional = true

[elements.rules]
typeof = "types.rules"
optional = true

[elements.secrets]
typeof = "types.secrets"
optional = true

