[types.cache]
type = "table"

    [types.cache.Type]
    type = "string"
    allowedvalues = [ "s3", "gcs", "azure" ]
    optional = true

    [types.cache.Path]
    type = "string"
    optional = true

    [types.cache.Shared]
    type = "boolean"
    optional = true

    [types.cache.MaxUploadedArchiveSize]
    type = "integer"
    min = 0
    optional = true

    [types.cache.s3]
    typeof = "types.cacheS3"
    optional = true

    [types.cache.gcs]
    typeof = "types.cacheGCS"
    optional = true

    [types.cache.azure]
    typeof = "types.cacheAzure"
    optional = true

[types.runner]
type = "collection"
typeof = "any"

    [types.runner.name]
    type = "string"
    optional = true

    [types.runner.url]
    type = "string"
    optional = true

    [types.runner.token]
    type = "string"
    optional = true

    [types.runner.tls-ca-file]
    type = "string"
    optional = true

    [types.runner.tls-cert-file]
    type = "string"
    optional = true

    [types.runner.tls-key-file]
    type = "string"
    optional = true

    [types.runner.limit]
    type = "integer"
    min = 0
    optional = true

    [types.runner.executor]
    typeof = "types.executor"
    optional = true

    [types.runner.shell]
    typeof = "types.shell"
    optional = true

    [types.runner.builds_dir]
    type = "string"
    optional = true

    [types.runner.cache_dir]
    type = "string"
    optional = true

    [types.runner.environment]
    typeof = "types.stringArray"
    optional = true

    [types.runner.request_concurrency]
    type = "integer"
    min = 1
    optional = true

    [types.runner.strict_check_interval]
    type = "boolean"
    optional = true

    [types.runner.output_limit]
    type = "integer"
    min = 0
    optional = true

    [types.runner.pre_clone_script]
    type = "string"
    optional = true

    [types.runner.post_clone_script]
