    optional = true

    [types.customExecutor.prepare_exec]
    type = "string"
    optional = true

    [types.customExecutor.prepare_args]
    typeof = "types.stringArray"
    optional = true

    [types.customExecutor.prepare_exec_timeout]
    type = "integer"
    min = 0
    optional = true

    [types.customExecutor.run_exec]
    type = "string"
    optional = true

    [types.customExecutor.run_args]
    typeof = "types.stringArray"
    optional = true

    [types.customExecutor.cleanup_exec]
    type = "string"
    optional = true

    [types.customExecutor.cleanup_args]
    typeof = "types.stringArray"
    optional = true

    [types.customExecutor.cleanup_exec_timeout]
    type = "integer"
    min = 0
    optional = true

    [types.customExecutor.graceful_kill_timeout]
    type = "integer"
    min = 0
    optional = true

    [types.customExecutor.force_kill_timeout]
    type = "integer"
    min = 0
    optional = true

