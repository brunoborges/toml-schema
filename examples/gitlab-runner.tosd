    optional = true

    [types.cacheS3.AssumeRoleMaxConcurrency]
    type = "integer"
    min = 1
    optional = true

[types.cacheGCS]
type = "table"

    [types.cacheGCS.CredentialsFile]
    type = "string"
    optional = true

    [types.cacheGCS.AccessID]
